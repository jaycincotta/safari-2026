---
const {
  title = 'Great Migration Safari 2026',
  description = 'A static-first safari companion for a 19-day Kenya and Tanzania journey.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--sand: #efe2c5;
		--sand-deep: #dbc190;
		--sun: #d58a3a;
		--clay: #a3552d;
		--olive: #5d6b43;
		--canopy: #304033;
		--ink: #1b1d1a;
		--mist: #f8f4ea;
		--card: rgba(248, 244, 234, 0.82);
		--line: rgba(27, 29, 26, 0.12);
		--shadow: 0 18px 40px rgba(27, 29, 26, 0.12);
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
		color: var(--ink);
		font-family: "Aptos", "Segoe UI", sans-serif;
		background:
			radial-gradient(circle at top left, rgba(213, 138, 58, 0.28), transparent 30%),
			radial-gradient(circle at top right, rgba(93, 107, 67, 0.18), transparent 25%),
			linear-gradient(180deg, #f3e5c9 0%, #f8f4ea 34%, #efe4cd 100%);
	}

	a {
		color: inherit;
	}

	.page-shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 32px 20px 72px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
		gap: 28px;
		align-items: stretch;
	}

	.hero-panel,
	.hero-aside,
	.section-card,
	.detail-hero,
	.detail-card {
		background: var(--card);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.5);
		box-shadow: var(--shadow);
		border-radius: 28px;
	}

	.hero-panel {
		padding: 36px;
		background:
			linear-gradient(140deg, rgba(48, 64, 51, 0.92), rgba(163, 85, 45, 0.86)),
			linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
		color: var(--mist);
	}

	.hero-aside,
	.section-card,
	.detail-card,
	.detail-hero {
		padding: 28px;
	}

	.eyebrow {
		margin: 0 0 10px;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		font-size: 0.75rem;
		font-weight: 700;
		opacity: 0.75;
	}

	h1,
	h2,
	h3 {
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
		line-height: 0.98;
		margin: 0;
	}

	h1 {
		font-size: clamp(2.8rem, 5vw, 5.7rem);
		max-width: 11ch;
	}

	h2 {
		font-size: clamp(1.7rem, 2.7vw, 2.5rem);
		margin-bottom: 12px;
	}

	.lead {
		font-size: 1.08rem;
		line-height: 1.7;
		max-width: 62ch;
	}

	.hero-actions,
	.stats,
	.route-strip,
	.media-grid,
	.stay-grid,
	.spotlight-grid,
	.itinerary-grid,
	.summary-stack,
	.synopsis-rail,
	.day-rail,
	.detail-body,
	.deep-dive-grid,
	.meta-grid,
	.day-browse,
	.day-nav {
		display: grid;
		gap: 16px;
	}

	.hero-actions {
		grid-auto-flow: column;
		justify-content: start;
		margin-top: 28px;
	}

	.button,
	.print-button,
	.back-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		padding: 12px 18px;
		font-weight: 700;
		text-decoration: none;
		border: 1px solid transparent;
	}

	.button--primary,
	.print-button {
		background: var(--sun);
		color: #fffdf7;
	}

	.button--ghost,
	.back-link {
		border-color: rgba(255, 255, 255, 0.3);
		background: rgba(255, 255, 255, 0.08);
		color: inherit;
	}

	.hero-aside {
		background:
			linear-gradient(180deg, rgba(239, 226, 197, 0.96), rgba(248, 244, 234, 0.96)),
			repeating-linear-gradient(
				135deg,
				rgba(93, 107, 67, 0.08) 0,
				rgba(93, 107, 67, 0.08) 12px,
				transparent 12px,
				transparent 24px
			);
	}

	.stats {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-top: 20px;
	}

	.stat {
		padding: 16px;
		border-radius: 20px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--line);
	}

	.stat strong,
	.meta-grid strong {
		display: block;
		font-size: 1.05rem;
		margin-top: 6px;
	}

	.section-stack {
		display: grid;
		gap: 22px;
		margin-top: 24px;
	}

	.route-strip {
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
	}

	.media-showcase {
		display: grid;
		gap: 18px;
	}

	.media-showcase__intro {
		max-width: 68ch;
	}

	.media-grid {
		grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
		align-items: start;
	}

	.media-grid--detail {
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}

	.media-showcase--detail {
		margin-top: 22px;
	}

	.media-figure {
		margin: 0;
		display: grid;
		gap: 12px;
	}

	.media-frame {
		display: block;
		border-radius: 24px;
		overflow: hidden;
		background: rgba(48, 64, 51, 0.12);
		border: 1px solid rgba(27, 29, 26, 0.08);
		box-shadow: var(--shadow);
	}

	.media-frame img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}

	.media-figure--feature .media-frame img {
		aspect-ratio: 16 / 9;
	}

	.media-caption {
		display: grid;
		gap: 4px;
		padding: 0 4px;
	}

	.media-caption strong {
		font-size: 1.02rem;
	}

	.media-caption span {
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.68;
	}

	.media-caption p {
		margin: 4px 0 0;
		line-height: 1.6;
		font-size: 0.94rem;
	}

	.media-caption a {
		color: var(--clay);
	}

	.route-stop,
	.stay-card,
	.spotlight,
	.day-card {
		padding: 18px;
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--line);
	}

	.route-stop span,
	.stay-card span,
	.spotlight span,
	.day-card span,
	.meta-grid span {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.65;
	}

	.stay-grid,
	.spotlight-grid,
	.itinerary-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.day-card {
		display: grid;
		gap: 12px;
	}

	.day-card h3,
	.route-stop strong,
	.stay-card strong,
	.spotlight strong {
		font-size: 1.2rem;
	}

	.day-card a,
	.day-nav a {
		text-decoration: none;
		font-weight: 700;
		color: var(--clay);
	}

	.note-list,
	.detail-list {
		margin: 0;
		padding-left: 20px;
		line-height: 1.7;
	}

	.detail-hero {
		margin-bottom: 22px;
	}

	.summary-stack {
		margin-top: 20px;
	}

	.synopsis-rail,
	.deep-dive-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.synopsis-card {
		padding: 18px;
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--line);
	}

	.synopsis-card span,
	.day-browse__link span,
	.day-browse__status span {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.68;
	}

	.synopsis-card p,
	.dive-card p {
		margin: 10px 0 0;
		line-height: 1.65;
	}

	.synopsis-card strong,
	.day-browse__link strong,
	.day-browse__status strong {
		display: block;
		margin-top: 6px;
		font-size: 1.05rem;
	}

	.synopsis-card--primary {
		background: linear-gradient(135deg, rgba(48, 64, 51, 0.92), rgba(93, 107, 67, 0.82));
		color: var(--mist);
	}

	.day-browse {
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: stretch;
		margin: 18px 0 20px;
	}

	.day-browse__link,
	.day-browse__status,
	.day-browse__spacer {
		padding: 14px 16px;
		border-radius: 18px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.5);
	}

	.day-browse__link {
		text-decoration: none;
	}

	.day-browse__link--next {
		text-align: right;
	}

	.day-browse__status {
		min-width: 180px;
		text-align: center;
	}

	.day-rail {
		grid-auto-flow: column;
		grid-auto-columns: minmax(240px, 1fr);
		overflow-x: auto;
		padding-bottom: 6px;
		scroll-snap-type: x proximity;
		margin-bottom: 20px;
	}

	.day-rail__card {
		padding: 18px;
		border-radius: 22px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.5);
		text-decoration: none;
		scroll-snap-align: start;
		min-height: 150px;
	}

	.day-rail__card span {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.68;
	}

	.day-rail__card strong {
		display: block;
		margin-top: 8px;
		font-size: 1.08rem;
	}

	.day-rail__card p {
		margin: 10px 0 0;
		line-height: 1.55;
		font-size: 0.96rem;
	}

	.day-rail__card--current {
		background: linear-gradient(135deg, rgba(213, 138, 58, 0.18), rgba(93, 107, 67, 0.18));
		border-color: rgba(163, 85, 45, 0.35);
	}

	.meta-grid {
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		margin-top: 22px;
	}

	.detail-body {
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	}

	.day-nav {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-top: 20px;
	}

	.day-nav span:last-child,
	.day-nav a:last-child {
		text-align: right;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.media-grid {
			grid-template-columns: 1fr;
		}

		.hero-actions {
			grid-auto-flow: row;
		}

		.stats {
			grid-template-columns: 1fr 1fr;
		}

		.day-browse {
			grid-template-columns: 1fr;
		}

		.day-rail {
			grid-auto-columns: minmax(260px, 86vw);
		}

		.day-browse__status,
		.day-browse__link--next {
			text-align: left;
		}
	}

	@media (max-width: 640px) {
		.page-shell {
			padding: 18px 14px 48px;
		}

		.hero-panel,
		.hero-aside,
		.section-card,
		.detail-card,
		.detail-hero {
			padding: 22px;
			border-radius: 24px;
		}

		h1 {
			max-width: none;
		}

		.stats,
		.day-nav {
			grid-template-columns: 1fr;
		}

		.day-nav span:last-child,
		.day-nav a:last-child {
			text-align: left;
		}
	}

	@media print {
		body {
			background: white;
		}

		.hero-panel,
		.hero-aside,
		.section-card,
		.detail-card,
		.detail-hero {
			box-shadow: none;
			border: 1px solid #d6d0c5;
			background: white;
		}

		.hero-actions,
		.print-button,
		.back-link,
		.day-nav {
			display: none;
		}

		a {
			text-decoration: none;
			color: inherit;
		}
	}
</style>
