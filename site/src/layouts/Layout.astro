---
const {
  title = 'Great Migration Safari 2026',
	description = 'Our 19-day safari through Kenya and Tanzania, with the route, stays, and day plans in one place.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--sand: #efe2c5;
		--sand-deep: #dbc190;
		--sun: #d58a3a;
		--clay: #a3552d;
		--olive: #5d6b43;
		--canopy: #304033;
		--ink: #1b1d1a;
		--mist: #f8f4ea;
		--card: rgba(248, 244, 234, 0.82);
		--line: rgba(27, 29, 26, 0.12);
		--shadow: 0 18px 40px rgba(27, 29, 26, 0.12);
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
		color: var(--ink);
		background:
			radial-gradient(circle at top left, rgba(213, 138, 58, 0.28), transparent 30%),
			radial-gradient(circle at top right, rgba(93, 107, 67, 0.18), transparent 25%),
			linear-gradient(180deg, #f3e5c9 0%, #f8f4ea 34%, #efe4cd 100%);
		font-family: "Aptos", "Segoe UI", sans-serif;
	}

	a {
		color: inherit;
	}

	.page-shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 32px 20px 72px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
		gap: 28px;
		align-items: stretch;
	}

	.hero-panel,
	.hero-aside,
	.section-card,
	.detail-hero,
	.detail-card {
		background: var(--card);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.5);
		box-shadow: var(--shadow);
	}

	.hero-panel {
		border-radius: 28px;
		padding: 36px;
		background:
			linear-gradient(140deg, rgba(48, 64, 51, 0.92), rgba(163, 85, 45, 0.86)),
			linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
		color: var(--mist);
	}

	.hero-aside,
	.section-card,
	.detail-card,
	.detail-hero {
		border-radius: 18px;
		padding: 28px;
	}

	.eyebrow {
		margin: 0 0 10px;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		font-size: 0.75rem;
		font-weight: 700;
		opacity: 0.75;
	}

	h1,
	h2,
	h3 {
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
		line-height: 0.98;
		margin: 0;
	}

	h1 {
		font-size: clamp(2.8rem, 5vw, 5.7rem);
	}

	.hero-panel h1 {
		max-width: 11ch;
	}

	h2 {
		font-size: clamp(1.7rem, 2.7vw, 2.5rem);
		margin-bottom: 12px;
	}

	.lead {
		font-size: 1.08rem;
		line-height: 1.7;
		max-width: 62ch;
	}

	.hero-actions,
	.stats,
	.route-strip,
	.media-grid,
	.stay-grid,
	.spotlight-grid,
	.itinerary-grid,
	.summary-stack,
	.synopsis-rail,
	.day-rail,
	.detail-body,
	.deep-dive-grid,
	.meta-grid,
	.day-browse,
	.day-nav {
		display: grid;
		gap: 16px;
	}

	.hero-actions {
		grid-auto-flow: column;
		justify-content: start;
		margin-top: 28px;
	}

	.hero-actions--home {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		grid-auto-flow: row;
		align-items: stretch;
		column-gap: 14px;
		row-gap: 12px;
		width: 100%;
	}

	.hero-actions--home > :nth-child(1) {
		grid-column: 1;
		grid-row: 1;
	}

	.hero-actions--home > :nth-child(2) {
		grid-column: 2;
		grid-row: 1;
	}

	.hero-actions--home > :nth-child(3) {
		grid-column: 1;
		grid-row: 2;
	}

	.hero-actions--home > :nth-child(4) {
		grid-column: 2;
		grid-row: 2;
	}

	.hero-actions--home > * {
		width: 100%;
		min-width: 0;
	}

	.button,
	.print-button,
	.back-link,
	.gallery-link {
		display: inline-flex;
		box-sizing: border-box;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		padding: 12px 18px;
		font-weight: 700;
		text-decoration: none;
		border: 1px solid transparent;
		transition:
			transform 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.button--primary,
	.print-button {
		background: var(--sun);
		color: #fffdf7;
	}

	.button--ghost,
	.back-link,
	.gallery-link {
		border-color: rgba(255, 255, 255, 0.34);
		background: rgba(255, 255, 255, 0.12);
		color: inherit;
	}

	.gallery-link {
		justify-self: start;
		border-color: var(--line);
		background: rgba(255, 255, 255, 0.68);
		color: var(--clay);
	}

	.button:hover,
	.print-button:hover,
	.back-link:hover,
	.gallery-link:hover,
	.button:focus-visible,
	.print-button:focus-visible,
	.back-link:focus-visible,
	.gallery-link:focus-visible {
		transform: translateY(-1px);
		box-shadow: 0 12px 24px rgba(27, 29, 26, 0.12);
	}

	.hero-aside {
		background:
			linear-gradient(180deg, rgba(239, 226, 197, 0.96), rgba(248, 244, 234, 0.96)),
			repeating-linear-gradient(
				135deg,
				rgba(93, 107, 67, 0.08) 0,
				rgba(93, 107, 67, 0.08) 12px,
				transparent 12px,
				transparent 24px
			);
	}

	.stats {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		margin-top: 20px;
	}

	.stat {
		padding: 16px;
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--line);
	}

	.stat strong,
	.meta-grid strong {
		display: block;
		font-size: 1.05rem;
		margin-top: 6px;
	}

	.section-stack {
		display: grid;
		gap: 22px;
		margin-top: 24px;
	}

	.route-strip {
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
	}

	.media-showcase {
		display: grid;
		gap: 18px;
	}

	.media-showcase__intro {
		max-width: 68ch;
	}

	.media-grid {
		grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
		align-items: start;
	}

	.media-grid--detail {
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 18px;
	}

	.gallery-grid__item[hidden] {
		display: none;
	}

	.gallery-grid__empty {
		margin: 18px 0 0;
		padding: 18px;
		border-radius: 12px;
		border: 1px dashed rgba(27, 29, 26, 0.18);
		background: rgba(255, 255, 255, 0.35);
	}

	.gallery-hero {
		display: grid;
		gap: 12px;
		padding-bottom: 18px;
	}

	.gallery-title-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
	}

	.gallery-title-row h1 {
		font-size: clamp(2rem, 5vw, 3.4rem);
	}

	.gallery-edit-button {
		flex: 0 0 auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 999px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.62);
		color: var(--clay);
		cursor: pointer;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			background-color 180ms ease,
			border-color 180ms ease;
	}

	.gallery-edit-button svg {
		width: 18px;
		height: 18px;
	}

	.gallery-edit-button:hover,
	.gallery-edit-button:focus-visible {
		transform: translateY(-1px);
		box-shadow: 0 12px 24px rgba(27, 29, 26, 0.1);
		border-color: rgba(163, 85, 45, 0.35);
	}

	.gallery-selection-note {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.45;
		color: rgba(27, 29, 26, 0.72);
	}

	.gallery-filter {
		display: grid;
		gap: 14px;
		margin-top: -6px;
		padding: 18px;
		border-radius: 16px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.58);
	}

	.gallery-filter[hidden] {
		display: none;
	}

	.gallery-filter__intro p:last-child {
		margin: 0;
		line-height: 1.5;
		font-size: 0.94rem;
	}

	.gallery-filter__status {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		gap: 10px;
	}

	.gallery-filter__clear {
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.64);
		color: var(--clay);
		border-radius: 999px;
		padding: 9px 14px;
		font: inherit;
		font-weight: 700;
		cursor: pointer;
	}

	.gallery-filter__clear:disabled {
		opacity: 0.45;
		cursor: default;
	}

	.calendar-grid {
		display: grid;
		grid-template-columns: repeat(7, minmax(0, 1fr));
		gap: 6px;
	}

	.calendar-grid__head {
		padding: 0 2px 2px;
		font-size: 0.66rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.65;
	}

	.calendar-grid__day,
	.calendar-grid__pad {
		min-height: 64px;
		border-radius: 10px;
		padding: 8px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.54);
		display: grid;
		align-content: start;
		gap: 4px;
		text-align: left;
	}

	.calendar-grid__day {
		cursor: pointer;
		font: inherit;
		transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease, background-color 180ms ease;
	}

	.calendar-grid__day:hover,
	.calendar-grid__day:focus-visible {
		transform: translateY(-1px);
		box-shadow: 0 12px 24px rgba(27, 29, 26, 0.12);
		border-color: rgba(163, 85, 45, 0.4);
	}

	.calendar-grid__day[data-selection-state='selected'] {
		background: linear-gradient(145deg, rgba(213, 138, 58, 0.24), rgba(93, 107, 67, 0.18));
		border-color: rgba(163, 85, 45, 0.42);
	}

	.calendar-grid__day[data-selection-state='pending'] {
		background: rgba(48, 64, 51, 0.12);
		border-color: rgba(48, 64, 51, 0.4);
		box-shadow: inset 0 0 0 1px rgba(48, 64, 51, 0.12);
	}

	.calendar-grid__day span,
	.calendar-grid__pad span {
		font-size: 0.62rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.66;
	}

	.calendar-grid__day strong,
	.calendar-grid__pad strong {
		font-size: 1rem;
		line-height: 1;
	}

	.calendar-grid__day em {
		font-style: normal;
		font-size: 0.68rem;
		color: var(--clay);
	}

	.calendar-grid__day i,
	.calendar-grid__pad i {
		display: none;
		font-style: normal;
		font-size: 0.66rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(27, 29, 26, 0.62);
	}

	.calendar-grid__pad {
		opacity: 0.42;
	}

	.media-showcase--detail {
		margin-top: 22px;
	}

	.media-figure {
		margin: 0;
		display: grid;
		gap: 12px;
	}

	.media-frame {
		display: block;
		position: relative;
		border-radius: 18px;
		overflow: hidden;
		background: rgba(48, 64, 51, 0.12);
		border: 1px solid rgba(27, 29, 26, 0.08);
		box-shadow: var(--shadow);
	}

	.media-frame img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}

	.media-figure--feature .media-frame img {
		aspect-ratio: 16 / 9;
	}

	.media-figure--gallery .media-frame img {
		aspect-ratio: 4 / 5;
	}

	.media-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: flex-end;
		padding: 18px;
		background: linear-gradient(180deg, rgba(27, 29, 26, 0.08), rgba(27, 29, 26, 0.82));
		color: var(--mist);
		opacity: 0;
		transition: opacity 180ms ease;
	}

	.media-figure--overlay:hover .media-overlay,
	.media-figure--overlay:focus-within .media-overlay {
		opacity: 1;
	}

	.media-overlay__inner {
		display: grid;
		gap: 8px;
	}

	.media-overlay__inner span {
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.72;
	}

	.media-overlay__inner strong {
		font-size: 1.02rem;
	}

	.media-overlay__links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 6px;
	}

	.media-overlay__links a {
		color: var(--mist);
		text-decoration: none;
		font-weight: 700;
	}

	.media-caption {
		display: grid;
		gap: 4px;
		padding: 0 4px;
	}

	.media-caption--subtle {
		padding: 2px 6px 0;
	}

	.media-caption--subtle p {
		margin: 0;
		font-size: 0.8rem;
		line-height: 1.4;
		opacity: 0.7;
	}

	.media-credit--personal {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		opacity: 0.76;
	}

	.media-credit--personal img {
		width: 22px;
		height: 22px;
		border-radius: 999px;
		border: 1px solid rgba(27, 29, 26, 0.1);
		box-shadow: 0 6px 16px rgba(27, 29, 26, 0.08);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.media-caption strong {
		font-size: 1.02rem;
	}

	.media-caption span {
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.68;
	}

	.media-caption p {
		margin: 4px 0 0;
		line-height: 1.6;
		font-size: 0.94rem;
	}

	.media-caption a {
		color: var(--clay);
	}

	.route-stop,
	.stay-card,
	.spotlight,
	.day-card {
		padding: 18px;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--line);
		border-top-width: 3px;
	}

	.route-stop {
		border-top-color: rgba(213, 138, 58, 0.42);
	}

	.stay-card {
		border-top-color: rgba(93, 107, 67, 0.42);
	}

	.spotlight {
		border-top-color: rgba(163, 85, 45, 0.42);
	}

	.day-card {
		border-top-color: rgba(48, 64, 51, 0.42);
	}

	.route-stop span,
	.stay-card span,
	.spotlight span,
	.day-card span,
	.meta-grid span {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.65;
	}

	.stay-grid,
	.spotlight-grid,
	.itinerary-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.day-card {
		display: grid;
		gap: 12px;
	}

	.day-card h3,
	.route-stop strong,
	.stay-card strong,
	.spotlight strong {
		font-size: 1.2rem;
	}

	.day-card a,
	.day-nav a {
		text-decoration: none;
		font-weight: 700;
		color: var(--clay);
	}

	.note-list,
	.detail-list {
		margin: 0;
		padding-left: 20px;
		line-height: 1.7;
	}

	.detail-hero {
		margin-bottom: 22px;
	}

	.detail-hero__bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
		margin-bottom: 18px;
	}

	.summary-stack {
		margin-top: 20px;
	}

	.synopsis-rail,
	.deep-dive-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.deep-dive-grid--detail {
		margin-top: 28px;
	}

	.synopsis-card {
		padding: 18px;
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--line);
	}

	.synopsis-card span,
	.day-browse__link span {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.68;
	}

	.synopsis-card p,
	.dive-card p {
		margin: 10px 0 0;
		line-height: 1.65;
	}

	.synopsis-card strong,
	.day-browse__link strong {
		display: block;
		margin-top: 6px;
		font-size: 1.05rem;
	}

	.synopsis-card--primary {
		background: linear-gradient(135deg, rgba(48, 64, 51, 0.92), rgba(93, 107, 67, 0.82));
		color: var(--mist);
	}

	.day-browse {
		display: flex;
		align-items: stretch;
		justify-content: space-between;
		margin: 0;
		min-width: min(100%, 360px);
	}

	.day-browse--start {
		justify-content: flex-start;
	}

	.day-browse--end {
		justify-content: flex-end;
	}

	.day-browse__link {
		padding: 14px 16px;
		border-radius: 14px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.5);
		min-width: 140px;
	}

	.day-browse__link {
		text-decoration: none;
	}

	.day-browse__link--next {
		text-align: right;
	}

	.day-rail {
		grid-auto-flow: column;
		grid-auto-columns: minmax(240px, 320px);
		overflow-x: auto;
		padding-bottom: 6px;
		scroll-snap-type: x proximity;
		margin-bottom: 20px;
	}

	.day-rail__card {
		padding: 18px;
		border-radius: 12px;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.5);
		text-decoration: none;
		scroll-snap-align: start;
		min-height: 150px;
	}

	.day-rail__card span {
		display: block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		opacity: 0.68;
	}

	.day-rail__card strong {
		display: block;
		margin-top: 8px;
		font-size: 1.08rem;
	}

	.day-rail__card p {
		margin: 10px 0 0;
		line-height: 1.55;
		font-size: 0.96rem;
	}

	.day-rail__card--current {
		background: linear-gradient(135deg, rgba(213, 138, 58, 0.18), rgba(93, 107, 67, 0.18));
		border-color: rgba(163, 85, 45, 0.35);
	}

	.meta-grid {
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		margin-top: 22px;
	}

	.detail-body {
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	}

	.day-nav {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		align-items: center;
		margin-top: 20px;
	}

	.day-nav__print {
		justify-self: center;
	}

	.day-nav span:last-child,
	.day-nav a:last-child {
		text-align: right;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.media-grid {
			grid-template-columns: 1fr;
		}

		.calendar-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 8px;
		}

		.calendar-grid__head {
			display: none;
		}

		.calendar-grid__day,
		.calendar-grid__pad {
			min-height: 0;
			grid-template-columns: auto minmax(0, 1fr) auto;
			grid-template-areas:
				"weekday month meta"
				"weekday date meta";
			align-items: center;
			column-gap: 10px;
				row-gap: 2px;
		}

		.calendar-grid__day span,
		.calendar-grid__pad span {
