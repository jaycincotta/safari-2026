---
import Layout from '../layouts/Layout.astro';
import ResponsivePhoto from '../components/ResponsivePhoto.astro';
import { formatItineraryDate } from '../data/dates';
import { companionContentBySlug, destinationSpotlights, itinerary, planningNotes, tripFacts } from '../data/itinerary';
import { getFeaturedPhotos, getPhotoCountByDay } from '../data/media-library';

const stayPlan = [
  { label: 'Nairobi', detail: 'Ole Sereni Hotel for the city arrival, conservation, and transition days.' },
  { label: 'Masai Mara', detail: 'Mara Fig Tree Camp for the pre-tour wildlife extension.' },
  { label: 'Amboseli', detail: 'Kilima Safari Camp with Kilimanjaro-facing safari access.' },
  { label: 'Karatu', detail: 'Country Lodge for the Ngorongoro stage and crater access.' },
  { label: 'Serengeti', detail: 'ThornTree Camp for three nights in the park ecosystem.' },
  { label: 'Lake Eyasi / Tarangire', detail: 'Lake Eyasi Safari Lodge and Sangaiwe Tented Lodge to close the route.' },
];

const routeStops = ['Nairobi', 'Masai Mara', 'Amboseli', 'Karatu', 'Serengeti', 'Lake Eyasi', 'Tarangire', 'Arusha'];
const featuredPhotos = getFeaturedPhotos();
const photoCountByDay = getPhotoCountByDay();
---

<Layout
	title="Great Migration Safari 2026"
	description="Our 19-day safari through Kenya and Tanzania, with the route, stays, and day plans in one place."
>
	<main class="page-shell">
		<section class="hero">
			<div class="hero-panel">
				<p class="eyebrow">Kenya + Tanzania | July 19 to August 6, 2026</p>
				<h1>Great Migration Safari 2026</h1>
				<p class="lead">
					We are tracing a 19-day route through Nairobi, the Masai Mara, Amboseli, Ngorongoro,
					the Serengeti, Lake Eyasi, and Tarangire. Use this to check what comes next, where we
					are sleeping, and the shape of each day.
				</p>
				<div class="hero-actions hero-actions--home">
					<a class="button button--primary" href="/itinerary/day-1/">Open day-by-day</a>
					<a class="button button--ghost" href="#itinerary">See the route</a>
					<a class="print-button" href="/gallery/">View photos</a>
					<a class="button button--ghost" href="/print/">Print itinerary</a>
				</div>
			</div>

			<aside class="hero-aside">
				<p class="eyebrow">Trip frame</p>
				<h2>What this trip covers</h2>
				<p class="lead">
					From arrival in Nairobi through the final drive back to Arusha, the trip alternates
					between long transfer days, full safari days, conservation visits, and a few cultural stops.
				</p>
				<div class="stats">
					<div class="stat">
						<span>Duration</span>
						<strong>{tripFacts.days} days</strong>
					</div>
					<div class="stat">
						<span>Meals</span>
						<strong>{tripFacts.meals}</strong>
					</div>
					<div class="stat">
						<span>Game drives</span>
						<strong>{tripFacts.gameDrives}</strong>
					</div>
					<div class="stat">
						<span>Countries</span>
						<strong>{tripFacts.countries}</strong>
					</div>
				</div>
			</aside>
		</section>

		<div class="section-stack">
			<section class="section-card">
				<p class="eyebrow">Route at a glance</p>
				<h2>The route</h2>
				<div class="route-strip">
					{routeStops.map((stop) => (
						<div class="route-stop">
							<span>Stop</span>
							<strong>{stop}</strong>
						</div>
					))}
				</div>
			</section>

			<section class="section-card media-showcase">
				<div class="media-showcase__intro">
					<p class="eyebrow">Along the route</p>
					<h2>Scenes to keep the stops recognizable</h2>
					<p class="lead">
						A few reference images make it easier to keep Amboseli, Ngorongoro, the Serengeti,
						and the rest of the route distinct as the days start to blend together.
					</p>
				</div>
				<div class="media-grid">
					{featuredPhotos.map((photo, index) => (
						<ResponsivePhoto
							photo={photo}
							loading={index === 0 ? 'eager' : 'lazy'}
							sizes={index === 0 ? '(min-width: 960px) 58vw, 100vw' : '(min-width: 960px) 42vw, 100vw'}
							class={index === 0 ? 'media-figure--feature' : ''}
						/>
					))}
				</div>
				<a class="gallery-link" href="/gallery/">Open the gallery</a>
			</section>

			<section class="section-card">
				<p class="eyebrow">Stay profile</p>
				<h2>Where we're staying</h2>
				<div class="stay-grid">
					{stayPlan.map((stay) => (
						<div class="stay-card">
							<span>Base</span>
							<strong>{stay.label}</strong>
							<p>{stay.detail}</p>
						</div>
					))}
				</div>
			</section>

			<section class="section-card">
				<p class="eyebrow">Destination spotlights</p>
				<h2>Why these stops matter</h2>
				<div class="spotlight-grid">
					{destinationSpotlights.map((spotlight) => (
						<div class="spotlight">
							<span>{spotlight.source}</span>
							<strong>{spotlight.name}</strong>
							<p>{spotlight.summary}</p>
						</div>
					))}
				</div>
			</section>

			<section class="section-card" id="itinerary">
				<p class="eyebrow">Day by day</p>
				<h2>The 19-day itinerary</h2>
				<div class="itinerary-grid">
					{itinerary.map((entry) => (
						<article class="day-card">
							<span>
								Day {entry.day} · {formatItineraryDate(entry.date, {
									month: 'short',
									day: 'numeric',
								})}
							</span>
							<h3>{entry.title}</h3>
							<p>{companionContentBySlug[entry.slug]?.synopsis ?? entry.summary}</p>
							<p><strong>Route:</strong> {entry.route}</p>
							<p><strong>Overnight:</strong> {entry.overnight}</p>
							<a href={`/itinerary/${entry.slug}/`}>View day details</a>
						</article>
					))}
				</div>
			</section>

			<section class="section-card">
				<p class="eyebrow">Before we go</p>
				<h2>Things to have ready</h2>
				<ul class="note-list">
					{planningNotes.map((note) => <li>{note}</li>)}
				</ul>
			</section>
		</div>
	</main>
</Layout>
