---
import Layout from '../layouts/Layout.astro';
import ResponsivePhoto from '../components/ResponsivePhoto.astro';
import { formatLocalIsoDate, parseItineraryDate } from '../data/dates';
import { itinerary } from '../data/itinerary';
import { getAllPhotos, getPhotoAppearances, getPhotoDaySlugs } from '../data/media-library';

const galleryItems = getAllPhotos().map((photo) => ({
  photo,
  appearances: getPhotoAppearances(photo),
	daySlugs: getPhotoDaySlugs(photo),
}));

const startDate = parseItineraryDate(itinerary[0].date);
const endDate = parseItineraryDate(itinerary[itinerary.length - 1].date);

const calendarStart = new Date(startDate);
calendarStart.setDate(startDate.getDate() - startDate.getDay());

const calendarEnd = new Date(endDate);
calendarEnd.setDate(endDate.getDate() + (6 - endDate.getDay()));

const calendarCells: Array<
	| {
			isoDate: string;
			dateLabel: string;
			label: number;
			monthLabel: string;
			day?: (typeof itinerary)[number];
			isInTrip: boolean;
		}
	| null
> = [];

for (let cursor = new Date(calendarStart); cursor <= calendarEnd; cursor.setDate(cursor.getDate() + 1)) {
	const isoDate = formatLocalIsoDate(cursor);
	const itineraryDay = itinerary.find((entry) => entry.date === isoDate);

	calendarCells.push({
		isoDate,
		dateLabel: cursor.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }),
		label: cursor.getDate(),
		monthLabel: cursor.toLocaleDateString('en-US', { month: 'short' }),
		day: itineraryDay,
		isInTrip: Boolean(itineraryDay),
	});
}

const calendarWeeks = [];
for (let index = 0; index < calendarCells.length; index += 7) {
	calendarWeeks.push(calendarCells.slice(index, index + 7));
}
---

<Layout
	title="Gallery | Great Migration Safari 2026"
	description="A visual guide to the places and wildlife along our safari route."
>
	<main class="page-shell">
		<section class="detail-hero gallery-hero">
			<a class="back-link" href="/">Back to itinerary overview</a>
			<div class="gallery-title-row">
				<h1 data-gallery-title>All safari dates</h1>
				<button
					class="gallery-edit-button"
					type="button"
					data-gallery-toggle
					aria-expanded="false"
					aria-controls="gallery-filter-panel"
					aria-label="Edit dates"
				>
					<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path d="M4 16.25V20h3.75L18.81 8.94l-3.75-3.75L4 16.25zm14.71-8.04a1.003 1.003 0 0 0 0-1.42l-1.5-1.5a1.003 1.003 0 0 0-1.42 0l-1.17 1.17 3.75 3.75 1.34-1.34z" fill="currentColor"/>
					</svg>
					<span class="sr-only">Edit dates</span>
				</button>
			</div>
			<p class="gallery-selection-note" data-gallery-selection-label>Showing all safari photos</p>
		</section>

		<section
			class="section-card gallery-filter"
			id="gallery-filter-panel"
			data-gallery-filter-panel
			aria-labelledby="gallery-filter-title"
			hidden
		>
			<div class="gallery-filter__intro">
				<h2 id="gallery-filter-title">Choose dates</h2>
				<p>Select one day to focus the gallery, or click a second day to select a range.</p>
			</div>
			<div class="gallery-filter__status">
				<button class="gallery-filter__clear" type="button" data-gallery-clear disabled>Show all</button>
			</div>
			<div class="calendar-grid" data-gallery-calendar>
				<div class="calendar-grid__head">Sun</div>
				<div class="calendar-grid__head">Mon</div>
				<div class="calendar-grid__head">Tue</div>
				<div class="calendar-grid__head">Wed</div>
				<div class="calendar-grid__head">Thu</div>
				<div class="calendar-grid__head">Fri</div>
				<div class="calendar-grid__head">Sat</div>
				{calendarWeeks.flat().map((cell) =>
					cell ? (
						cell.isInTrip && cell.day ? (
							<button
								type="button"
								class="calendar-grid__day"
								data-day-slug={cell.day.slug}
								data-day-number={cell.day.day}
								data-day-title={cell.day.title}
								data-date-label={cell.dateLabel}
								aria-pressed="false"
							>
								<span>{cell.monthLabel}</span>
								<strong>{cell.label}</strong>
								<em>Day {cell.day.day}</em>
							</button>
						) : (
							<div class="calendar-grid__pad" aria-hidden="true">
								<span>{cell.monthLabel}</span>
								<strong>{cell.label}</strong>
							</div>
						)
					) : null,
				)}
			</div>
		</section>

		<section class="section-card">
			<div class="gallery-grid" data-gallery-grid>
				{galleryItems.map(({ photo, appearances, daySlugs }, index) => (
					<article class="gallery-grid__item" data-gallery-item data-day-slugs={daySlugs.join(' ')}>
						<ResponsivePhoto
							photo={photo}
							overlayLinks={appearances}
							overlayLabel="Linked days"
							loading={index < 6 ? 'eager' : 'lazy'}
							sizes="(min-width: 1100px) 28vw, (min-width: 720px) 44vw, 100vw"
							class="media-figure--gallery"
						/>
					</article>
				))}
			</div>
			<p class="gallery-grid__empty" data-gallery-empty hidden>No photos match the selected day range yet.</p>
		</section>
	</main>
</Layout>

<script is:inline>
	const dayButtons = Array.from(document.querySelectorAll('[data-day-slug]'));
	const galleryItems = Array.from(document.querySelectorAll('[data-gallery-item]'));
	const galleryTitle = document.querySelector('[data-gallery-title]');
	const selectionLabel = document.querySelector('[data-gallery-selection-label]');
	const clearButton = document.querySelector('[data-gallery-clear]');
	const emptyState = document.querySelector('[data-gallery-empty]');
	const filterPanel = document.querySelector('[data-gallery-filter-panel]');
	const toggleButton = document.querySelector('[data-gallery-toggle]');

	let startDay = null;
	let endDay = null;
	let isFilterOpen = false;
	let pendingStartDay = null;

	const dayMeta = dayButtons.map((button) => ({
		slug: button.dataset.daySlug,
		dayNumber: Number(button.dataset.dayNumber),
		title: button.dataset.dayTitle,
		dateLabel: button.dataset.dateLabel,
		button,
	}));

	const dayMetaBySlug = new Map(dayMeta.map((day) => [day.slug, day]));

	function getSelectedRange() {
		if (!startDay) return [];
		if (!endDay) return [startDay];

		const low = Math.min(startDay.dayNumber, endDay.dayNumber);
		const high = Math.max(startDay.dayNumber, endDay.dayNumber);
		return dayMeta.filter((day) => day.dayNumber >= low && day.dayNumber <= high);
	}

	function updateLabel(selectedRange) {
		if (!selectionLabel) return;
		if (isFilterOpen) {
			if (!pendingStartDay) {
				selectionLabel.textContent = 'Selection mode: choose a start date, then a second date for a range.';
				return;
			}

			selectionLabel.textContent = `Selection mode: ${pendingStartDay.dateLabel} is selected. Tap it again for one day, or choose another date to finish the range.`;
			return;
		}

		if (!selectedRange.length) {
			selectionLabel.textContent = 'Showing all safari photos';
			return;
		}
		if (selectedRange.length === 1) {
			selectionLabel.textContent = `Showing photos for Day ${selectedRange[0].dayNumber} · ${selectedRange[0].title}`;
			return;
		}
		selectionLabel.textContent = `Showing photos for Days ${selectedRange[0].dayNumber}–${selectedRange[selectedRange.length - 1].dayNumber}`;
	}

	function updateTitle(selectedRange) {
		if (!galleryTitle) return;

		if (!selectedRange.length) {
			galleryTitle.textContent = 'All safari dates';
			return;
		}

		if (selectedRange.length === 1) {
			galleryTitle.textContent = selectedRange[0].dateLabel;
			return;
		}

		galleryTitle.textContent = `${selectedRange[0].dateLabel} - ${selectedRange[selectedRange.length - 1].dateLabel}`;
	}

	function updateButtons(selectedRange) {
		const selectedSlugs = new Set(selectedRange.map((day) => day.slug));
		dayMeta.forEach((day) => {
			if (isFilterOpen && pendingStartDay) {
				const isPending = pendingStartDay.slug === day.slug;
				day.button.setAttribute('aria-pressed', isPending ? 'true' : 'false');
				day.button.dataset.selectionState = isPending ? 'pending' : '';
				return;
			}

			const isSelected = selectedSlugs.has(day.slug);
			day.button.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
			day.button.dataset.selectionState = isSelected ? 'selected' : '';
		});
	}

	function updateGallery(selectedRange) {
		const selectedSlugs = new Set(selectedRange.map((day) => day.slug));
		let visibleCount = 0;

		galleryItems.forEach((item) => {
			const itemSlugs = (item.getAttribute('data-day-slugs') || '').split(/\s+/).filter(Boolean);
			const isVisible = !selectedRange.length || itemSlugs.some((slug) => selectedSlugs.has(slug));
			item.hidden = !isVisible;
			if (isVisible) visibleCount += 1;
		});

		if (emptyState) {
			emptyState.hidden = visibleCount !== 0;
		}
	}

	function syncQuery(selectedRange) {
		const url = new URL(window.location.href);
		url.searchParams.delete('day');
		url.searchParams.delete('startDay');
		url.searchParams.delete('endDay');

		if (selectedRange.length === 1) {
			url.searchParams.set('day', selectedRange[0].slug);
		} else if (selectedRange.length > 1) {
			url.searchParams.set('startDay', selectedRange[0].slug);
			url.searchParams.set('endDay', selectedRange[selectedRange.length - 1].slug);
		}

		window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
	}

	function syncFilterPanel() {
		const shouldShow = isFilterOpen;

		if (filterPanel) {
			filterPanel.hidden = !shouldShow;
		}

		if (toggleButton) {
			toggleButton.setAttribute('aria-expanded', shouldShow ? 'true' : 'false');
			toggleButton.setAttribute('aria-label', shouldShow ? 'Close date selector' : 'Edit dates');
		}
	}

	function commitSelection(nextStartDay, nextEndDay = null) {
		startDay = nextStartDay;
		endDay = nextEndDay;
		pendingStartDay = null;
		isFilterOpen = false;
		syncUi();
	}

	function syncUi() {
		const selectedRange = getSelectedRange();
		updateLabel(selectedRange);
		updateTitle(selectedRange);
		updateButtons(selectedRange);
		updateGallery(selectedRange);
		syncQuery(selectedRange);
		syncFilterPanel();
		if (clearButton) clearButton.disabled = selectedRange.length === 0;
	}

	dayMeta.forEach((day) => {
		day.button.addEventListener('click', () => {
			if (!isFilterOpen) {
				return;
			}

			if (!pendingStartDay) {
				pendingStartDay = day;
				syncUi();
				return;
			}

			if (pendingStartDay.slug === day.slug) {
				commitSelection(day, null);
				return;
			}

			commitSelection(pendingStartDay, day);
		});
	});

	clearButton?.addEventListener('click', () => {
		startDay = null;
		endDay = null;
		pendingStartDay = null;
		isFilterOpen = false;
		syncUi();
	});

	toggleButton?.addEventListener('click', () => {
		isFilterOpen = !isFilterOpen;
		pendingStartDay = null;
		syncUi();
	});

	const initialParams = new URLSearchParams(window.location.search);
	const initialDay = initialParams.get('day');
	const initialStartDay = initialParams.get('startDay');
	const initialEndDay = initialParams.get('endDay');

	if (initialDay && dayMetaBySlug.has(initialDay)) {
		startDay = dayMetaBySlug.get(initialDay) ?? null;
	} else if (initialStartDay && dayMetaBySlug.has(initialStartDay)) {
		startDay = dayMetaBySlug.get(initialStartDay) ?? null;
		if (initialEndDay && dayMetaBySlug.has(initialEndDay)) {
			endDay = dayMetaBySlug.get(initialEndDay) ?? null;
		}
	}

	syncUi();
</script>