---
import Layout from '../layouts/Layout.astro';
import ResponsivePhoto from '../components/ResponsivePhoto.astro';
import { getAllPhotos, getPhotoAppearances } from '../data/media-library';

const galleryItems = getAllPhotos().map((photo) => ({
  photo,
  appearances: getPhotoAppearances(photo),
}));
---

<Layout
	title="Gallery | Great Migration Safari 2026"
	description="A full gallery of the licensed safari photography used across the itinerary site."
>
	<main class="page-shell">
		<section class="detail-hero">
			<a class="back-link" href="/">Back to itinerary overview</a>
			<p class="eyebrow">Gallery</p>
			<h1>Safari image library</h1>
			<p class="lead">
				Every optimized image in one place. Hover any photo to see which itinerary pages reuse it,
				then jump straight to those pages.
			</p>
		</section>

		<section class="section-card">
			<div class="gallery-grid">
				{galleryItems.map(({ photo, appearances }, index) => (
					<ResponsivePhoto
						photo={photo}
						overlayLinks={appearances}
						loading={index < 4 ? 'eager' : 'lazy'}
						sizes="(min-width: 1100px) 28vw, (min-width: 720px) 44vw, 100vw"
						class="media-figure--gallery"
					/>
				))}
			</div>
		</section>
	</main>
</Layout>