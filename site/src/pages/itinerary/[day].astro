---
import Layout from '../../layouts/Layout.astro';
import ResponsivePhoto from '../../components/ResponsivePhoto.astro';
import { companionContentBySlug, itinerary } from '../../data/itinerary';
import { getPhotosForDay } from '../../data/media-library';

export function getStaticPaths() {
  return itinerary.map((entry) => ({
    params: { day: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const currentIndex = itinerary.findIndex((item) => item.slug === entry.slug);
const previous = currentIndex > 0 ? itinerary[currentIndex - 1] : null;
const next = currentIndex < itinerary.length - 1 ? itinerary[currentIndex + 1] : null;
const companion = companionContentBySlug[entry.slug];
const nearbyDays = itinerary.slice(Math.max(0, currentIndex - 2), Math.min(itinerary.length, currentIndex + 3));
const photos = getPhotosForDay(entry);

const formattedDate = new Date(entry.date).toLocaleDateString('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Layout title={`Day ${entry.day} | Great Migration Safari 2026`} description={entry.summary}>
  <main class="page-shell">
    <section class="detail-hero">
      <a class="back-link" href="/#itinerary">Back to full itinerary</a>
      <nav class="day-browse" aria-label="Quick browse between days">
        {previous ? (
          <a class="day-browse__link" href={`/itinerary/${previous.slug}/`}>
            <span>Previous</span>
            <strong>Day {previous.day}</strong>
          </a>
        ) : (
          <span class="day-browse__spacer" />
        )}
        <div class="day-browse__status">
          <span>Quick browse</span>
          <strong>Day {entry.day} of {itinerary.length}</strong>
        </div>
        {next ? (
          <a class="day-browse__link day-browse__link--next" href={`/itinerary/${next.slug}/`}>
            <span>Next</span>
            <strong>Day {next.day}</strong>
          </a>
        ) : (
          <span class="day-browse__spacer" />
        )}
      </nav>
      <section class="day-rail" aria-label="Swipeable nearby day summaries">
        {nearbyDays.map((dayItem) => {
          const summary = companionContentBySlug[dayItem.slug]?.synopsis ?? dayItem.summary;
          const isCurrent = dayItem.slug === entry.slug;

          return (
            <a
              class:list={['day-rail__card', isCurrent && 'day-rail__card--current']}
              href={`/itinerary/${dayItem.slug}/`}
              aria-current={isCurrent ? 'page' : undefined}
            >
              <span>
                Day {dayItem.day} · {new Date(dayItem.date).toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
              <strong>{dayItem.title}</strong>
              <p>{summary}</p>
            </a>
          );
        })}
      </section>
      <p class="eyebrow">Day {entry.day}</p>
      <h1>{entry.title}</h1>
      <div class="summary-stack">
        <article class="synopsis-card synopsis-card--primary">
          <span>At a glance</span>
          <p>{companion.synopsis}</p>
        </article>
      </div>
      <p class="lead">{companion.richerSummary}</p>

      <div class="meta-grid">
        <div>
          <span>Date</span>
          <strong>{formattedDate}</strong>
        </div>
        <div>
          <span>Route</span>
          <strong>{entry.route}</strong>
        </div>
        <div>
          <span>Overnight</span>
          <strong>{entry.overnight}</strong>
        </div>
        <div>
          <span>Meals</span>
          <strong>{entry.meals.length ? entry.meals.join(', ') : 'In transit'}</strong>
        </div>
      </div>
    </section>

    <section class="detail-body">
      <article class="detail-card">
        <h2>What Defines This Day</h2>
        <ul class="detail-list">
          {entry.highlights.map((item: string) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="detail-card">
        <h2>Look Out For</h2>
        <ul class="detail-list">
          {companion.featuredMoments.map((item: string) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="detail-card">
        <h2>Practical Notes</h2>
        <ul class="detail-list">
          {companion.practicalNotes.map((item: string) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="detail-card">
        <h2>For the day</h2>
        <p>
			  Keep this page as the quick reference for the route, the overnight stop, and the few
			  moments we most want to remember before heading out.
        </p>
        <button class="print-button" type="button" onclick="window.print()">Print this day</button>
      </article>
    </section>

    {photos.length ? (
      <section class="section-card media-showcase media-showcase--detail" aria-label="Curated photography for this day">
        <div class="media-showcase__intro">
          <p class="eyebrow">Field gallery</p>
		  <h2>Scenes from this stretch of the trip</h2>
          <p class="lead">
			  These photos are here to help us place the landscape, wildlife, and feel of the day before
			  we are back in the vehicle.
          </p>
        </div>
        <div class="media-grid media-grid--detail">
          {photos.map((photo, index) => (
            <ResponsivePhoto
              photo={photo}
              loading={index === 0 ? 'eager' : 'lazy'}
              sizes="(min-width: 960px) 33vw, 100vw"
              showAttribution={true}
            />
          ))}
        </div>
      </section>
    ) : null}

    <section class="deep-dive-grid" aria-label="Richer context for this day">
      {companion.deeperDive.map((item) => (
        <article class="detail-card dive-card">
          <span class="eyebrow">Read Deeper</span>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
        </article>
      ))}
    </section>

    <nav class="day-nav" aria-label="Day navigation">
      {previous ? <a href={`/itinerary/${previous.slug}/`}>Previous: Day {previous.day}</a> : <span />}
      {next ? <a href={`/itinerary/${next.slug}/`}>Next: Day {next.day}</a> : <span />}
    </nav>
  </main>
</Layout>
